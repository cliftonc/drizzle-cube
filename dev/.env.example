# Database Configuration (matches dev/docker-compose.yml - port 54821)
DATABASE_URL=postgresql://drizzle_user:drizzle_pass123@localhost:54821/drizzle_cube_db

# Server Configuration
PORT=3001

# Environment
NODE_ENV=development

# Gemini AI Configuration (for AI Query Generation)
# MAX_GEMINI_CALLS=1000
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3-flash-preview

# ============================================================================
# Agent Notebook — LLM Provider Configuration
# ============================================================================
# Set AGENT_PROVIDER to choose which LLM powers the agentic notebook.
# Only the API key for your chosen provider is required.
#
# Supported providers:
#   anthropic  — Claude models (default)
#   openai     — OpenAI models (also works with Groq, Together, Mistral, Ollama via AGENT_BASE_URL)
#   google     — Google Gemini models

# AGENT_PROVIDER=anthropic
# AGENT_MODEL=                     # Leave blank for provider default

# --- Anthropic (default) ---
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- OpenAI ---
# OPENAI_API_KEY=sk-xxx
# AGENT_BASE_URL=                  # Leave blank for OpenAI, or set for compatible providers:
                                   #   Groq:     https://api.groq.com/openai/v1
                                   #   Together: https://api.together.xyz/v1
                                   #   Mistral:  https://api.mistral.ai/v1
                                   #   Ollama:   http://localhost:11434/v1

# --- Google Gemini ---
# GOOGLE_API_KEY=AIzaSyxxx

# ============================================================================
# Langfuse Observability (optional)
# ============================================================================
# LANGFUSE_ENABLED=true
# LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
